<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.shoeshop.controller.OrderFormController"
            minWidth="550" minHeight="420">

    <!-- ── Заголовок ─────────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="12">
            <Label text="Карточка заказа" styleClass="page-title"/>
        </HBox>
    </top>

    <!-- ── Тело формы ────────────────────────────────────────────────── -->
    <center>
        <VBox styleClass="form-container" spacing="12">
            <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>

            <!-- ID -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="ID:" styleClass="form-label"/>
                <Label fx:id="idLabel" styleClass="form-id-label"/>
            </HBox>

            <!-- Артикул -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Артикул заказа:" styleClass="form-label"/>
                <TextField fx:id="articleField"
                           promptText="Например: ORD-2026-001"
                           styleClass="form-field"
                           HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Статус -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Статус:" styleClass="form-label"/>
                <ComboBox fx:id="statusCombo"
                          promptText="Выберите статус"
                          styleClass="form-field"
                          HBox.hgrow="ALWAYS"
                          maxWidth="Infinity"/>
            </HBox>

            <!-- Адрес пункта выдачи -->
            <HBox alignment="TOP_LEFT" spacing="10">
                <Label text="Адрес выдачи:" styleClass="form-label"/>
                <TextArea fx:id="addressArea"
                          promptText="Город, улица, номер ПВЗ"
                          prefHeight="70"
                          wrapText="true"
                          styleClass="form-field"
                          HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Дата заказа -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Дата заказа:" styleClass="form-label"/>
                <DatePicker fx:id="orderDatePicker"
                            promptText="дд.мм.гггг"
                            styleClass="form-field"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"/>
            </HBox>

            <!-- Дата доставки -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Дата доставки:" styleClass="form-label"/>
                <DatePicker fx:id="deliveryDatePicker"
                            promptText="дд.мм.гггг (необязательно)"
                            styleClass="form-field"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"/>
            </HBox>
        </VBox>
    </center>

    <!-- ── Кнопки ─────────────────────────────────────────────────────── -->
    <bottom>
        <HBox styleClass="footer-bar" alignment="CENTER_RIGHT" spacing="10">
            <Button text="Отмена"
                    onAction="#handleCancel"
                    styleClass="btn-secondary"/>
            <Button text="Сохранить"
                    onAction="#handleSave"
                    styleClass="btn-accent"
                    defaultButton="true"/>
        </HBox>
    </bottom>
</BorderPane>
